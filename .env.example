# Anthropic API Key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Firebase (optional — enables Google Sign-In and cross-device report sync)
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=

# Razorpay (set TEST_MODE=false in code and add your live key)
VITE_RAZORPAY_KEY=rzp_live_...

# Google OAuth Client ID (enables uploading blog images to Google Drive)
# Create one at https://console.cloud.google.com/apis/credentials
# - Application type: Web application
# - Enable the Google Drive API for the project
# - Add your site's URL to "Authorized JavaScript origins"
VITE_GOOGLE_CLIENT_ID=
